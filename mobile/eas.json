{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.18.0",
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      },
      "env": {
        "JAVA_VERSION": "17"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.18.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "JAVA_VERSION": "17"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.18.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "JAVA_VERSION": "17"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
