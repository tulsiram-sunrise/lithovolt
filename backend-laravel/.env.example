APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=https://www.lithovolt.com.au

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend_laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

# CORS Configuration
# Development: max_age=0 (no caching)
# Production: max_age=86400 (24 hours caching)
CORS_MAX_AGE=0

# App Store URLs for Download Redirect
ANDROID_APP_URL=https://play.google.com/store/apps/details?id=au.com.lithovolt
IOS_APP_URL=https://apps.apple.com/app/lithovolt/id1234567890
WEB_LANDING_URL=https://www.lithovolt.com.au
PUSHER_APP_CLUSTER=mt1

# Registration lookup provider (vehicle by plate/rego)
REGISTRATION_PROVIDER_ENABLED=false
REGISTRATION_PROVIDER_DRIVER=null
REGISTRATION_PROVIDER_NAME=none
REGISTRATION_LOOKUP_CACHE_TTL=1440
REGISTRATION_PROVIDER_HTTP_URL=
REGISTRATION_PROVIDER_HTTP_METHOD=GET
REGISTRATION_PROVIDER_HTTP_TOKEN=
REGISTRATION_PROVIDER_HTTP_TOKEN_HEADER=Authorization
REGISTRATION_PROVIDER_HTTP_TOKEN_PREFIX=Bearer
REGISTRATION_PROVIDER_HTTP_VEHICLE_PATH=vehicle
REGISTRATION_PROVIDER_HTTP_REGO_PARAM=registration_number
REGISTRATION_PROVIDER_HTTP_STATE_PARAM=state_code
REGISTRATION_PROVIDER_HTTP_MARKET_PARAM=market
REGISTRATION_PROVIDER_HTTP_TIMEOUT=10

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
